# MySQL Konfigürasyonu
DB_USER=cari_user
DB_PASSWORD=1234
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cari_takip_db

# Sunucu Konfigürasyonu
PORT=3000
HOST=localhost

# Node Ortamı
NODE_ENV=development

# JWT Konfigürasyonu
JWT_SECRET=your-secure-secret-key-change-in-production-12345678!
JWT_EXPIRE=7d

# CORS Konfigürasyonu
CORS_ORIGIN=*
# Üretim ortamında belirli domain'lere sınırlandırın: http://localhost:3000,https://yourdomain.com

