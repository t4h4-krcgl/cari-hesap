# MySQL Konfigürasyonu
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_db_name

# Sunucu Konfigürasyonu
PORT=3000
HOST=localhost

# Node Ortamı
NODE_ENV=development

# JWT Konfigürasyonu
JWT_SECRET=your_jwt_secret
JWT_EXPIRE=7d

# CORS Konfigürasyonu
CORS_ORIGIN=*
